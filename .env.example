# ============================================================================
# 这个文件只是「模板/说明」，应用运行时从不读取它。
# This file is a TEMPLATE only — the running app never reads it.
#
# 真正生效的环境变量在哪里配置：
#   • 本地开发  -> 复制本文件为 .env（.env 会被 git 忽略，不会上传）
#   • EdgeOne 生产 -> 在 EdgeOne 控制台「环境变量」里配置，不需要任何 .env 文件
# ============================================================================

# --- 存储驱动（仅对「本地 dev / Next.js 服务端模式」有意义）---
# local   = 本地 JSON 文件存储（本地开发默认，无需任何数据库）
# edgeone = EdgeOne Pages KV（需要先注入 KV 绑定，见 src/lib/store/edgeone.ts）
#
# ⚠️ 重要：如果你用的是「EdgeOne Pages Function」方式部署后端
#    （edgeone/pages-function-reference.js），后端直接读取绑定的 KV 命名空间，
#    根本不会经过这个变量——这时 STORAGE_DRIVER 无需、也无法在 EdgeOne 上生效。
STORAGE_DRIVER=local

# --- 会话签名密钥（>= 16 字符）---
# 本地开发用任意字符串即可；生产环境务必在 EdgeOne 控制台设成强随机串。
# 生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string
